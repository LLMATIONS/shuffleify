# Spotify Developer Dashboard credentials.
# Get these from https://developer.spotify.com/dashboard for your "Shuffleify (LLMATIONS)" app.
SPOTIFY_CLIENT_ID=replace-me-from-developer-dashboard
SPOTIFY_CLIENT_SECRET=replace-me-from-developer-dashboard

# Redirect URI registered on the Spotify app.
# Local dev (basePath /shuffleify): http://127.0.0.1:3000/shuffleify/api/auth/callback
# Production: https://swagcounty.com/shuffleify/api/auth/callback
SPOTIFY_REDIRECT_URI=replace-me-with-the-redirect-uri-you-registered

# Session cookie encryption key. Minimum 32 chars; 64 random bytes (base64) recommended.
# Generate (PowerShell):
#   $b = New-Object byte[] 64; [System.Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($b); [Convert]::ToBase64String($b)
SESSION_PASSWORD=replace-me-with-64-byte-base64-output
